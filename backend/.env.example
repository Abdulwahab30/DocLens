# --- PostgreSQL ---
# Async URL (asyncpg driver) used by both the running app and Alembic migrations
# (Alembic's "async" template runs migrations through the async engine via run_sync)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/multimodal_rag

# --- Redis (Celery broker + result backend for the async ingestion pipeline) ---
REDIS_URL=redis://localhost:6379/0

# --- Auth / JWT (fastapi-users) ---
# Generate a real secret with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-me-to-a-long-random-string

# --- OpenRouter (LLM provider) ---
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=openai/gpt-oss-20b:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Vision-capable model used to describe images/figures extracted from PDFs
OPENROUTER_VISION_MODEL=google/gemini-2.0-flash-exp:free

# --- MinIO / S3-compatible object storage (raw uploaded files) ---
# Defaults match the docker-compose "minio" service (console at http://localhost:9001)
MINIO_ENDPOINT_URL=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=documents

# --- Qdrant (vector store for chunk embeddings) ---
# Defaults match the docker-compose "qdrant" service
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=document_chunks

# --- Local embedding model (sentence-transformers, runs in the Celery worker) ---
# Downloaded from HuggingFace on first use and cached locally — no API key needed.
# bge-small-en-v1.5 produces 384-dimensional vectors (must match EMBEDDING_DIMENSIONS
# and the Qdrant collection's vector size).
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSIONS=384
